diff --git a/src/dyncall/dyncall/dyncall_callvm_arm64_aggr.c b/src/dyncall/dyncall/dyncall_callvm_arm64_aggr.c
new file mode 100644
index 0000000..d05f760
--- /dev/null
+++ b/src/dyncall/dyncall/dyncall_callvm_arm64_aggr.c
@@ -0,0 +1,283 @@
+/*
+
+ Package: dyncall
+ Library: dyncall
+ File: dyncall/dyncall_callvm_arm64_aggr.c
+ Description: ARM 64-bit aggregate by-value helpers
+ License:
